APP_NAME=PearlHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pearlhub
DB_USERNAME=postgres
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8000
SESSION_DOMAIN=localhost

CORS_ALLOWED_ORIGINS=http://localhost:3000

# Meilisearch
SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=

# Laravel Reverb (WebSocket for Chat)
REVERB_APP_ID=pearlhub
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080

# Payment Gateways (PayHere removed — replaced with WebXPay, Genie, Koko, Mint)
WEBXPAY_MERCHANT_ID=
WEBXPAY_SECRET_KEY=
WEBXPAY_SANDBOX=true

GENIE_MERCHANT_ID=
GENIE_SECRET_KEY=
GENIE_SANDBOX=true

KOKO_MERCHANT_ID=
KOKO_SECRET_KEY=
KOKO_SANDBOX=true

MINT_MERCHANT_ID=
MINT_SECRET_KEY=
MINT_SANDBOX=true

# AI Services
ANTHROPIC_API_KEY=
XAI_API_KEY=

# Translation
GOOGLE_TRANSLATE_API_KEY=
LIBRETRANSLATE_URL=https://libretranslate.com

# Voice Transcription
OPENAI_API_KEY=
DEEPGRAM_API_KEY=

# Supabase (Flutter realtime)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# Mail
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@pearlhub.lk
MAIL_FROM_NAME="PearlHub"

# Frontend URL
FRONTEND_URL=http://localhost:3000
